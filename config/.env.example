# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=bsms_db
DB_PORT=3306

# Application
APP_NAME=BSMS
APP_URL=http://localhost/bsms-burger-shop
APP_ENV=development

# Security
SESSION_TIMEOUT=86400
JWT_SECRET=your_secret_key_here
CSRF_PROTECTION=true

# Email (optional)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM=noreply@bsms.local

# Business Settings
BUSINESS_NAME=Burger Shop
BUSINESS_ADDRESS=123 Main Street
BUSINESS_PHONE=+63-999-999-9999
BUSINESS_EMAIL=info@bsms.local

# Currency
CURRENCY_CODE=PHP
CURRENCY_SYMBOL=₱
DECIMAL_PLACES=2